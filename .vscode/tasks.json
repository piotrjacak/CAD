{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/std:c++17",
                "/I", "${workspaceFolder}\\include",
                "/I", "${workspaceFolder}\\src",
                "${workspaceFolder}\\src\\*.cpp",
                "${workspaceFolder}\\src\\objects\\*.cpp",
                "${workspaceFolder}\\src\\imgui\\*.cpp",
                "${workspaceFolder}\\src\\glad.c",
                "/Fo${workspaceFolder}/obj/",
                "/Fe:", "${workspaceFolder}\\src\\cad.exe",
                "/Fd:", "${workspaceFolder}\\src\\cad.pdb",
                "/MDd",
                "/link",
                "/NODEFAULTLIB:MSVCRT",
                "/LIBPATH:${workspaceFolder}\\lib",
                "glfw3.lib",
                "opengl32.lib",
                "kernel32.lib",
                "user32.lib",
                "gdi32.lib",
                "shell32.lib",
                "comdlg32.lib"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}